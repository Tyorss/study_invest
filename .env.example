NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used by cron routes and external scheduler calls
CRON_SECRET=

# Optional separate password for manual admin update tools.
# Falls back to CRON_SECRET when omitted.
ADMIN_JOB_SECRET=

# Preferred: ordered fallback chain (left -> right)
# TWELVE | YAHOO | YFINANCE | FDR | ALPHA
MARKET_DATA_PROVIDERS=TWELVE,YAHOO,YFINANCE,FDR

# Legacy single value (still supported). REAL is treated as TWELVE.
MARKET_DATA_PROVIDER=

# Required when TWELVE exists in MARKET_DATA_PROVIDERS (or MARKET_DATA_PROVIDER=TWELVE/REAL)
TWELVE_DATA_API_KEY=

# Optional Python binary for YFINANCE/FDR fallback
MARKET_DATA_PYTHON_BIN=

# Optional extra market holidays (comma-separated YYYY-MM-DD)
MARKET_HOLIDAYS_KR=
MARKET_HOLIDAYS_US=
